# Local development Caddyfile
:80 {
    # DeepSeek AI proxy — solves CORS, hides API key from browser
    handle /ai/* {
        header {
            Access-Control-Allow-Origin *
            Access-Control-Allow-Methods "GET, POST, OPTIONS"
            Access-Control-Allow-Headers "Content-Type, Authorization"
        }
        @options method OPTIONS
        respond @options 204

        uri strip_prefix /ai
        reverse_proxy https://api.deepseek.com {
            header_up Host api.deepseek.com
            header_up Authorization "Bearer {$DEEPSEEK_API_KEY}"
        }
    }

    # n8n webhook proxy with CORS
    handle /webhook/* {
        header {
            Access-Control-Allow-Origin *
            Access-Control-Allow-Methods "GET, POST, OPTIONS"
            Access-Control-Allow-Headers "Content-Type, Authorization"
        }
        @options method OPTIONS
        respond @options 204
        reverse_proxy n8n:5678
    }

    # Demo Dashboard
    handle_path /demo/* {
        root * /srv/demo-dashboard
        file_server
    }
    handle /demo {
        redir /demo/ permanent
    }

    # n8n UI proxy
    handle_path /n8n/* {
        reverse_proxy n8n:5678
    }

    # Flowise proxy
    handle_path /flowise/* {
        reverse_proxy flowise:3000
    }

    # Default — serve dashboard
    handle {
        root * /srv/demo-dashboard
        file_server
    }
}
