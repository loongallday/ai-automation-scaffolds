# === n8n ===
N8N_HOST=n8n.yourdomain.com
WEBHOOK_URL=https://n8n.yourdomain.com/
N8N_ENCRYPTION_KEY=change-me-to-random-string

# === PostgreSQL ===
POSTGRES_DB=restaurant_automation
POSTGRES_USER=automation
POSTGRES_PASSWORD=change-me

# === LINE Messaging API ===
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
ADMIN_LINE_USER_ID=your-line-user-id

# === DeepSeek ===
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# === Google Business (for review reply) ===
GOOGLE_BUSINESS_ACCOUNT_ID=your-account-id
GOOGLE_BUSINESS_LOCATION_ID=your-location-id

# === Domain ===
DOMAIN=yourdomain.com
