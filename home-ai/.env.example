# === n8n ===
N8N_HOST=n8n.local
WEBHOOK_URL=http://n8n.local:7777/
N8N_ENCRYPTION_KEY=change-me-to-random-string

# === PostgreSQL ===
POSTGRES_DB=home_automation
POSTGRES_USER=automation
POSTGRES_PASSWORD=change-me

# === Open WebUI ===
OLLAMA_BASE_URL=http://host.docker.internal:11434
WEBUI_SECRET_KEY=change-me-to-random-string

# === DeepSeek (optional, for cloud AI) ===
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# === Google Calendar (for morning briefing) ===
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# === Email (for email summary) ===
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password

# === LINE (for notifications) ===
LINE_NOTIFY_TOKEN=your-line-notify-token
